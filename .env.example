# ─── Slack App credentials ────────────────────────────────────────────────────
# Get these from https://api.slack.com/apps → your app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Socket Mode app-level token (requires connections:write scope)
# Get from https://api.slack.com/apps → your app → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-1-your-app-token-here

# ─── Notion credentials ────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_your-notion-integration-token-here

# ─── Notion Database IDs ───────────────────────────────────────────────────────
# Copy the DB ID from the Notion page URL:
# https://www.notion.so/workspace/DATABASE-ID?v=...
NOTION_DB_TASKS=your-notion-tasks-database-id-here
NOTION_DB_REVIEW=your-notion-review-database-id-here
